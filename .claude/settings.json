{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(python3 -c \"import json,sys; print\\(json.load\\(sys.stdin\\)['scripts']\\)\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(curl -s -o /tmp/build.html -w \"status=%{http_code} size=%{size_download}\\\\n\" http://localhost:3000/build)",
      "Bash(curl -s http://localhost:3000/players.json)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\('players.json served OK,', len\\(d\\), 'players'\\)\")",
      "Skill(browse)",
      "Skill(browse:*)",
      "Bash(git commit -m ' *)",
      "Bash(python3 -c \"import xgboost; print\\(xgboost.__version__\\)\")",
      "Bash(.venv/bin/python3 scripts/export_for_web.py)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ]
  }
}
