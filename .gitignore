.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.cache/
.DS_Store
*.egg-info/
build/
dist/

# Next.js route folder collides with the global build/ rule above.
!web/app/build/
!web/app/build/**

# soccerdata cache + raw pulls
data/cache/
data/raw/
data/interim/

# Manual review artifacts (player ID match queue) - keep schema, ignore content
data/review_queue/*.csv

# Trained models
data/models/*.pkl
data/models/*.json

# predictions/ artifacts ARE checked in (small, useful as repo demo)

# Notebook outputs
notebooks/*.ipynb_checkpoints/

# Vercel local state (org/project IDs, pulled env). IDs go into GitHub Actions
# secrets, not into the repo. .env.local is environment-specific and never committed.
web/.vercel/
web/.env.local
web/.env*.local

# Yarn 4 install state — keep yarn.lock, ignore everything else yarn writes.
web/.yarn/cache/
web/.yarn/install-state.gz
web/.pnp.*

# Playwright MCP debug artifacts (browser_eval console logs + screenshots)
.playwright-mcp/
